# Copy to .env next to docker-compose.yml to override local defaults.
# All values here are dev-only; real deployments use a cloud secret manager (DESIGN.md Section 11).
POSTGRES_PASSWORD=scriptorium-dev
NEO4J_PASSWORD=scriptorium-dev
JWT_SECRET=dev-only-secret-change-me
# Set to true only when TLS terminates in front of the BFF (cloud mode).
COOKIE_SECURE=false
# Local models (ADR-0004). Changing EMBED_MODEL requires re-ingesting documents.
EMBED_MODEL=nomic-embed-text
CHAT_MODEL=llama3.2:3b
