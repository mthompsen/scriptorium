# Build context: repo root
FROM python:3.12-slim AS build
ENV VIRTUAL_ENV=/opt/venv
RUN python -m venv "$VIRTUAL_ENV"
ENV PATH="$VIRTUAL_ENV/bin:$PATH"
WORKDIR /build
COPY packages/llm ./packages/llm
# [anthropic] extra: the agent can run its loop/judge on the Anthropic API
RUN pip install --no-cache-dir "./packages/llm[anthropic]"
COPY services/agent/pyproject.toml ./
COPY services/agent/src ./src
RUN pip install --no-cache-dir .

FROM python:3.12-slim
ENV VIRTUAL_ENV=/opt/venv PATH="/opt/venv/bin:$PATH"
COPY --from=build /opt/venv /opt/venv
RUN useradd --system --create-home appuser
USER appuser
EXPOSE 8002
# --timeout 300: local CPU LLM inference legitimately exceeds gunicorn's
# 30s default (ADR-0004); threads keep /health responsive during a long answer.
CMD ["gunicorn", "--bind", "0.0.0.0:8002", "--timeout", "300", "--workers", "2", "--threads", "4", "agent_service:create_app()"]
