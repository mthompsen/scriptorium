{
  "consumer": {
    "name": "bff"
  },
  "interactions": [
    {
      "description": "a neighborhood lookup",
      "providerStates": [
        {
          "name": "entity abc123def456 has related entities"
        }
      ],
      "request": {
        "method": "GET",
        "path": "/graph/entity/abc123def456/neighborhood",
        "query": {
          "tenant_id": [
            "11111111-1111-4111-8111-111111111111"
          ]
        }
      },
      "response": {
        "body": {
          "edges": [
            {
              "confidence": 0.9,
              "relation": "owns",
              "source": "abc123def456",
              "target": "def456abc123"
            }
          ],
          "nodes": [
            {
              "id": "abc123def456",
              "name": "Aurelia Corp",
              "type": "organization"
            }
          ]
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.edges": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type",
                  "min": 1
                }
              ]
            },
            "$.edges[*].confidence": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "decimal"
                }
              ]
            },
            "$.edges[*].relation": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.edges[*].source": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.edges[*].target": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.nodes": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type",
                  "min": 1
                }
              ]
            },
            "$.nodes[*].id": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.nodes[*].name": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.nodes[*].type": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 200
      }
    },
    {
      "description": "an entity search",
      "providerStates": [
        {
          "name": "entities exist for the demo tenant"
        }
      ],
      "request": {
        "method": "GET",
        "path": "/graph/search",
        "query": {
          "q": [
            "aurelia"
          ],
          "tenant_id": [
            "11111111-1111-4111-8111-111111111111"
          ]
        }
      },
      "response": {
        "body": {
          "entities": [
            {
              "id": "abc123def456",
              "mention_count": 4,
              "name": "Aurelia Corp",
              "type": "organization"
            }
          ]
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.entities": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type",
                  "min": 1
                }
              ]
            },
            "$.entities[*].id": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.entities[*].mention_count": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "integer"
                }
              ]
            },
            "$.entities[*].name": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.entities[*].type": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 200
      }
    }
  ],
  "metadata": {
    "pact-js": {
      "version": "17.0.1"
    },
    "pactRust": {
      "ffi": "0.5.4",
      "models": "1.3.11"
    },
    "pactSpecification": {
      "version": "3.0.0"
    }
  },
  "provider": {
    "name": "retrieval"
  }
}